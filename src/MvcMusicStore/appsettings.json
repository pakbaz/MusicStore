{
  "AppSettings": {
    "DefaultAdminUsername": "Administrator",
    "DefaultAdminPassword": "YouShouldChangeThisPassword"
  },
  "Cosmos": {
    "Database": "musicstore"
  },
  "Storage": {
    "ThumbnailsContainer": "thumbnails",
    "MusicContainer": "music"
  },
  "MusicGen": {
    "DefaultDurationSeconds": 30,
    "TimeoutSeconds": 600
  },
  "AiMusicCreation": {
    "DefaultPrice": 8.99,
    "PlaceholderAlbumArtUrl": "~/Images/placeholder.svg"
  },
  "Email": {
    "Enabled": true,
    "Provider": "Log",
    "FromAddress": "DoNotReply@localhost",
    "FromName": "MVC Music Store",
    "ConnectionString": "",
    "Endpoint": "",
    "BaseUrl": "",
    "LogDirectory": ""
  },
  "AbandonedCart": {
    "Enabled": true,
    "StartupDelaySeconds": 30,
    "ScanIntervalMinutes": 15,
    "ReminderAfterMinutes": 60,
    "ResendAfterHours": 72,
    "IncentiveCode": "",
    "BatchSize": 50
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AlbumMetadataEnrichment": {
    "Enabled": true,
    "StartupDelaySeconds": 5,
    "IntervalHours": 24,
    "BatchSize": 25,
    "RequestDelayMilliseconds": 1200
  },
  "ThumbnailCache": {
    "RelativeDirectory": "Images/MetadataCache",
    "MaxBytes": 5242880
  }
}
