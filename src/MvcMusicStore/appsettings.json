{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=MvcMusicStore.Identity.db",
    "MusicStoreEntities": "Data Source=MvcMusicStore.db"
  },
  "AppSettings": {
    "DefaultAdminUsername": "Administrator",
    "DefaultAdminPassword": "YouShouldChangeThisPassword"
  },
  "AiMusicCreation": {
    "DefaultPrice": 8.99,
    "PlaceholderAlbumArtUrl": "~/Images/placeholder.svg"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AlbumMetadataEnrichment": {
    "Enabled": true,
    "StartupDelaySeconds": 5,
    "IntervalHours": 24,
    "BatchSize": 25,
    "RequestDelayMilliseconds": 1200
  },
  "ThumbnailCache": {
    "RelativeDirectory": "Images/MetadataCache",
    "MaxBytes": 5242880
  }
}
