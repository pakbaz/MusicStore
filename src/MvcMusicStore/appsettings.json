{
  "AppSettings": {
    "DefaultAdminUsername": "Administrator",
    "DefaultAdminPassword": "YouShouldChangeThisPassword"
  },
  "Loyalty": {
    "PointsPerDollar": 10,
    "PointsPerDollarRedeemed": 100,
    "RedemptionIncrement": 100,
    "ReferrerRewardPoints": 500,
    "RefereeRewardPoints": 250,
    "ReferralCodeLength": 8,
    "Tiers": [
      { "Name": "Bronze", "MinimumLifetimeSpend": 0, "EarnMultiplier": 1.0 },
      { "Name": "Silver", "MinimumLifetimeSpend": 50, "EarnMultiplier": 1.25 },
      { "Name": "Gold", "MinimumLifetimeSpend": 150, "EarnMultiplier": 1.5 },
      { "Name": "Platinum", "MinimumLifetimeSpend": 300, "EarnMultiplier": 2.0 }
    ]
  },
  "Cosmos": {
    "Database": "musicstore"
  },
  "Storage": {
    "ThumbnailsContainer": "thumbnails",
    "MusicContainer": "music"
  },
  "MusicGen": {
    "DefaultDurationSeconds": 30,
    "TimeoutSeconds": 600
  },
  "AiMusicCreation": {
    "DefaultPrice": 8.99,
    "PlaceholderAlbumArtUrl": "~/Images/placeholder.svg"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AlbumMetadataEnrichment": {
    "Enabled": true,
    "StartupDelaySeconds": 5,
    "IntervalHours": 24,
    "BatchSize": 25,
    "RequestDelayMilliseconds": 1200
  },
  "ThumbnailCache": {
    "RelativeDirectory": "Images/MetadataCache",
    "MaxBytes": 5242880
  }
}
