@model MvcMusicStore.ViewModels.HomeIndexViewModel

@{
    ViewBag.Title = "Home Page";
}

<section class="hero-panel" aria-label="Featured music">
    <div class="hero-copy">
        <p class="hero-kicker">Featured right now</p>
        <h1>Discover albums you will want on repeat.</h1>
        <p class="hero-text">
            Browse curated genres, explore best sellers, and build your cart with a cleaner music shopping experience.
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary btn-lg" href="@Url.Action("Index", "Store")">Browse the catalog</a>
        </div>
    </div>
    <div class="hero-media">
        <img src="~/Images/home-showcase.png" alt="Music showcase artwork" />
    </div>
</section>

@if (Model.DealOfTheDay is { } deal)
{
    <section class="deal-panel" aria-label="Deal of the Day">
        <div class="deal-copy">
            <p class="deal-kicker">Deal of the Day</p>
            <h2 class="deal-title">@deal.Album.Title</h2>
            <p class="deal-artist">by @deal.Album.Artist?.Name</p>
            <p class="deal-pricing">
                <span class="price-was">@deal.Pricing.OriginalPrice.ToString("C")</span>
                <span class="price-now">@deal.Pricing.EffectivePrice.ToString("C")</span>
                @if (deal.Pricing.PercentOff is int percentOff)
                {
                    <span class="deal-percent">@percentOff% off</span>
                }
            </p>
            <div class="deal-countdown" data-deal-ends-utc="@deal.EndsUtc.ToString("o")" role="timer" aria-live="polite">
                <span class="deal-countdown-label">Hurry — ends in</span>
                <span class="deal-countdown-clock" data-deal-countdown>--:--:--</span>
            </div>
            <div class="deal-actions">
                <a class="btn btn-primary btn-lg" href="@Url.Action("AddToCart", "ShoppingCart", new { id = deal.Album.AlbumId })">Add to cart</a>
                <a class="btn btn-default btn-lg" href="@Url.Action("Details", "Store", new { id = deal.Album.AlbumId })">View album</a>
            </div>
        </div>
        <div class="deal-media">
            <span class="sale-badge deal-media-badge">@(deal.Pricing.PercentOff is int pct ? $"{pct}% off" : "On sale")</span>
            <img alt="@deal.Album.Title" src="@Url.Content(deal.Album.GetDisplayThumbnailUrl())" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" />
        </div>
    </section>
}

<section class="content-section" aria-label="Featured releases">
    <div class="section-heading">
        <h2>Featured releases</h2>
        <a class="section-link" href="@Url.Action("Index", "Store")">View all genres</a>
    </div>
    <div class="album-grid">
    @foreach (var album in Model.FeaturedReleases)
    {
        @await Html.PartialAsync("_AlbumCard", MvcMusicStore.ViewModels.AlbumCardViewModel.FromAlbum(album, Model.Pricing, album.Artist?.Name))
    }
    </div>
</section>

<section class="content-section">
    <div class="section-heading">
        <h2>Trending now</h2>
        <a class="section-link" href="@Url.Action("Index", "Store")">Browse genres</a>
    </div>
    <div class="album-grid">
    @foreach (var album in Model.TrendingReleases)
    {
        @await Html.PartialAsync("_AlbumCard", MvcMusicStore.ViewModels.AlbumCardViewModel.FromAlbum(album, Model.Pricing, album.Artist?.Name))
    }
    </div>
</section>

<section class="content-section">
    <div class="section-heading">
        <h2>Curated picks</h2>
        <a class="section-link" href="@Url.Action("Index", "Store")">See catalog</a>
    </div>
    <div class="album-grid">
    @foreach (var album in Model.CuratedReleases)
    {
        @await Html.PartialAsync("_AlbumCard", MvcMusicStore.ViewModels.AlbumCardViewModel.FromAlbum(album, Model.Pricing, album.Artist?.Name))
    }
    </div>
</section>

@section scripts {
    <script src="~/Scripts/deal-countdown.js"></script>
}
