@model MvcMusicStore.ViewModels.HomeIndexViewModel

@{
    ViewBag.Title = "Home Page";
}

<div class="jumbotron">
    <div class="row text-center">
        <img src="~/Images/home-showcase.png" />
    </div>
</div>

<section class="discovery-section">
    <h2>Featured Releases</h2>
    <ul class="row list-unstyled album-grid">
        @foreach (var album in Model.FeaturedReleases)
        {
            <li class="col-lg-2 col-md-2 col-sm-3 col-xs-6 container">
                <a href="@Url.Action("Details", "Store", new { id = album.AlbumId })">
                    <img alt="@album.Title" src="@Url.Content(album.AlbumArtUrl)" />
                    <h4>@album.Title</h4>
                </a>
                <small class="text-muted">@album.Artist?.Name</small>
            </li>
        }
    </ul>
</section>

<section class="discovery-section">
    <h2>Trending Now</h2>
    <ul class="row list-unstyled album-grid">
