@model MvcMusicStore.ViewModels.HomeIndexViewModel

@{
    ViewBag.Title = "Home";

    var siteUrl = Url.AbsoluteContent("~/");
    var storeUrl = Url.Action("Index", "Store", null, Context.Request.Scheme) ?? siteUrl;
    var searchTemplate = $"{storeUrl}?search={{search_term_string}}";
    var logoUrl = Url.AbsoluteContent(Seo.LogoPath);

    ViewBag.Seo = new SeoMetadata
    {
        Title = "Buy albums, preview tracks, and create AI music",
        Description = Seo.DefaultDescription,
        OgType = "website"
    };
}

<section class="hero-panel" aria-label="Featured music">
    <div class="hero-copy">
        <p class="hero-kicker">Featured right now</p>
        <h1>Discover albums you will want on repeat.</h1>
        <p class="hero-text">
            Browse curated genres, explore best sellers, and build your cart with a cleaner music shopping experience.
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary btn-lg" href="@Url.Action("Index", "Store")">Browse the catalog</a>
        </div>
    </div>
    <div class="hero-media">
        <img src="~/Images/home-showcase.png" alt="Music showcase artwork" />
    </div>
</section>

<section class="content-section" aria-label="Top selling albums">
    <div class="section-heading">
        <h2>Featured releases</h2>
        <a class="section-link" href="@Url.Action("Index", "Store")">View all genres</a>
    </div>
    <div class="album-grid">
    @foreach (var album in Model.FeaturedReleases)
    {
        <article class="album-card">
            <a class="album-card-link" href="@Url.AlbumUrl(album.AlbumId, album.Title)">
                <img alt="@album.Title" src="@Url.Content(album.GetDisplayThumbnailUrl())" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" />
                <div class="album-card-body">
                    <h3 class="album-title">@album.Title</h3>
                    <p class="album-price">@album.Artist?.Name</p>
                </div>
            </a>
            <div class="album-card-actions">
                @await Component.InvokeAsync("WishlistButton", new { albumId = album.AlbumId })
            </div>
        </article>
    }
    </div>
</section>

<section class="content-section">
    <div class="section-heading">
        <h2>Trending now</h2>
        <a class="section-link" href="@Url.Action("Index", "Store")">Browse genres</a>
    </div>
    <div class="album-grid">
    @foreach (var album in Model.TrendingReleases)
    {
        <article class="album-card">
            <a class="album-card-link" href="@Url.AlbumUrl(album.AlbumId, album.Title)">
                <img alt="@album.Title" src="@Url.Content(album.GetDisplayThumbnailUrl())" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" />
                <div class="album-card-body">
                    <h3 class="album-title">@album.Title</h3>
                    <p class="album-price">@album.Price.ToString("C")</p>
                </div>
            </a>
            <div class="album-card-actions">
                @await Component.InvokeAsync("WishlistButton", new { albumId = album.AlbumId })
            </div>
        </article>
    }
    </div>
</section>

<section class="content-section">
    <div class="section-heading">
        <h2>Curated picks</h2>
        <a class="section-link" href="@Url.Action("Index", "Store")">See catalog</a>
    </div>
    <div class="album-grid">
    @foreach (var album in Model.CuratedReleases)
    {
        <article class="album-card">
            <a class="album-card-link" href="@Url.AlbumUrl(album.AlbumId, album.Title)">
                <img alt="@album.Title" src="@Url.Content(album.GetDisplayThumbnailUrl())" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" />
                <div class="album-card-body">
                    <h3 class="album-title">@album.Title</h3>
                    <p class="album-price">@album.Artist?.Name</p>
                </div>
            </a>
            <div class="album-card-actions">
                @await Component.InvokeAsync("WishlistButton", new { albumId = album.AlbumId })
            </div>
        </article>
    }
    </div>
</section>

@Html.Raw(StructuredData.HomeGraph(siteUrl, searchTemplate, logoUrl))
