@model IEnumerable<MvcMusicStore.Models.Genre>
@{
    ViewBag.Title = "Browse Genres";
}

<section class="content-section">
    <div class="section-heading">
        <h1>Browse genres</h1>
        <p class="section-subtitle">Pick from @Model.Count() genres and jump straight to the albums you love.</p>
    </div>
    <div class="genre-grid">
    @foreach (var genre in Model)
    {
        <a class="genre-card" href="@Url.Action("Browse", new { genre = genre.Name })">
            <span class="genre-name">@genre.Name</span>
            <span class="genre-action">Explore</span>
        </a>
    }
    </div>
</section>
