@model MvcMusicStore.ViewModels.CatalogIndexViewModel
@{
    ViewBag.Title = "Catalog";
    ViewBag.Seo = new SeoMetadata
    {
        Title = "Browse the music catalog",
        Description = "Browse and buy albums across genres on MVC Music Store. " +
            "Filter by genre, price, and availability, preview tracks, and add favorites to your cart.",
        OgType = "website"
    };
}

<section class="content-section" aria-label="Store catalog filters">
    <h1>Catalog</h1>
    @using (Html.BeginForm("Index", "Store", FormMethod.Get, new { @class = "form-inline", role = "search", aria_label = "Filter catalog" }))
    {
        <div class="form-group">
            <label class="sr-only" for="search">Search</label>
            <input class="form-control" id="search" name="search" placeholder="Album, artist, or genre" type="text" value="@Model.Search" />
        </div>
        <div class="form-group">
            <label class="sr-only" for="genre">Genre</label>
            <select class="form-control" id="genre" name="genre">
                <option value="">All genres</option>
                @foreach (var genre in Model.Genres)
                {
                    <option value="@genre" selected="@(Model.Genre == genre)">@genre</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label class="sr-only" for="minPrice">Min price</label>
            <input class="form-control" id="minPrice" min="0" name="minPrice" placeholder="Min price" step="0.01" type="number" value="@Model.MinPrice" />
        </div>
        <div class="form-group">
            <label class="sr-only" for="maxPrice">Max price</label>
            <input class="form-control" id="maxPrice" min="0" name="maxPrice" placeholder="Max price" step="0.01" type="number" value="@Model.MaxPrice" />
        </div>
        <div class="form-group">
            <label class="sr-only" for="availability">Availability</label>
            <select class="form-control" id="availability" name="availability">
                <option value="all" selected="@(Model.Availability == "all")">All availability</option>
                <option value="available" selected="@(Model.Availability == "available")">In stock</option>
                <option value="unavailable" selected="@(Model.Availability == "unavailable")">Out of stock</option>
            </select>
        </div>
        <div class="form-group">
            <label class="sr-only" for="sort">Sort</label>
            <select class="form-control" id="sort" name="sort">
                <option value="popularity_desc" selected="@(Model.Sort == "popularity_desc")">Popularity</option>
                <option value="rating_desc" selected="@(Model.Sort == "rating_desc")">Top rated</option>
                <option value="release_desc" selected="@(Model.Sort == "release_desc")">Release date (newest)</option>
                <option value="release_asc" selected="@(Model.Sort == "release_asc")">Release date (oldest)</option>
                <option value="price_asc" selected="@(Model.Sort == "price_asc")">Price (low to high)</option>
                <option value="price_desc" selected="@(Model.Sort == "price_desc")">Price (high to low)</option>
            </select>
        </div>
        <button class="btn btn-primary" type="submit">Apply</button>
        <a class="btn btn-link" href="@Url.Action("Index", "Store")">Clear filters</a>
    }
</section>

<section class="content-section" aria-label="Catalog results">
    <p class="text-muted">
        @Model.TotalResults result(s)
    </p>

    @if (!Model.Albums.Any())
    {
        <div class="alert alert-info">
            No albums match the current search and filter combination.
        </div>
    }
    else
    {
        <ul id="album-list" class="list-unstyled">
            @foreach (var album in Model.Albums)
            {
                <li>
                    <a href="@Url.AlbumUrl(album.AlbumId, album.Title)">
                        <span class="album-thumb">
                            <img alt="@album.Title" src="@Url.Content(album.AlbumArtUrl)" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" />
                            @if (album.IsOnSale)
                            {
                                <span class="sale-badge sale-badge-overlay" title="@album.SaleName">Sale</span>
                            }
                        </span>
                        <h2 class="h5">@album.Title</h2>
                    </a>
                    <small class="text-muted">@album.ArtistName</small>
                    <small class="text-muted">
                        @album.GenreName ·
                        @if (album.IsOnSale)
                        {
                            <span class="price-was">@album.Price.ToString("C")</span>
                            <span class="price-now">@album.EffectivePrice.ToString("C")</span>
                        }
                        else
                        {
                            <span>@album.Price.ToString("C")</span>
                        }
                    </small>
                    <div class="album-card-rating">
                        @await Html.PartialAsync("_StarRating", new MvcMusicStore.ViewModels.StarRatingViewModel { Average = album.AverageRating, Count = album.ReviewCount })
                    </div>
                    <small class="text-muted">Released: @(album.ReleaseDate?.ToString("yyyy-MM-dd") ?? "Unknown")</small>
                    @if (album.IsAvailable)
                    {
                        <span class="label label-success">In stock</span>
                    }
                    else
                    {
                        <span class="label label-default">Out of stock</span>
                    }
                    @if (album.HasPreview)
                    {
                        @await Html.PartialAsync("_AlbumPreviewPlayer", new MvcMusicStore.ViewModels.AudioPreviewViewModel
                        {
                            PreviewUrl = album.PreviewUrl!,
                            DurationSeconds = album.PreviewDurationSeconds,
                            Title = album.Title,
                            Variant = "card"
                        })
                    }
                    <div class="catalog-item-actions">
                        @await Component.InvokeAsync("WishlistButton", new { albumId = album.AlbumId })
                    </div>
                </li>
            }
        </ul>
    }

    @if (Model.TotalPages > 1)
    {
        <nav class="catalog-pagination" aria-label="Catalog pagination">
            @if (Model.HasPreviousPage)
            {
                <a class="btn btn-default" rel="prev" href="@Url.Action("Index", "Store", new { search = Model.Search, genre = Model.Genre, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, availability = Model.Availability, sort = Model.Sort, page = Model.Page - 1 })">Previous</a>
            }
            <span class="text-muted">Page @Model.Page of @Model.TotalPages</span>
            @if (Model.HasNextPage)
            {
                <a class="btn btn-default" rel="next" href="@Url.Action("Index", "Store", new { search = Model.Search, genre = Model.Genre, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, availability = Model.Availability, sort = Model.Sort, page = Model.Page + 1 })">Next</a>
            }
        </nav>
    }
</section>
