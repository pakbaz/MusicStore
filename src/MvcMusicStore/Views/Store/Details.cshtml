@model MvcMusicStore.ViewModels.AlbumDetailsViewModel

@{
    ViewBag.Title = "Album - " + Model.Album.Title;
}

<article class="album-detail">
    <div class="album-detail-art">
        <img alt="@Model.Album.Title" src="@Url.Content(Model.Album.GetDisplayThumbnailUrl())" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" />
    </div>
    <div class="album-detail-content">
        <p class="detail-kicker">@Model.Album.Genre!.Name</p>
        <h1>@Model.Album.Title</h1>
        <p class="detail-artist">
            by @Html.ActionLink(Model.Album.Artist!.Name, "Artist", "Store", new { id = Model.Album.ArtistId }, null)
        </p>
        <p class="detail-price">@Model.Album.Price.ToString("C")</p>
        <div class="detail-actions">
            <a class="btn btn-primary btn-lg"
               href="@Url.Action("AddToCart", "ShoppingCart", new { id = Model.Album.AlbumId })"
               aria-label="Add @Model.Album.Title to cart">
                <span class="glyphicon glyphicon-shopping-cart" aria-hidden="true"></span>
                Add to cart
            </a>
            <a class="btn btn-default btn-lg" href="@Url.Action("Browse", "Store", new { genre = Model.Album.Genre.Name })">
                Back to @Model.Album.Genre.Name
            </a>
        </div>
    </div>
</article>

@if (Model.Bundles.Count > 0)
{
    <section class="content-section">
        <div class="section-heading">
            <h2>Complete the set</h2>
            <p class="section-subtitle">Bundle @Model.Album.Title with more music and save.</p>
        </div>
        <div class="bundle-grid">
            @foreach (var bundle in Model.Bundles)
            {
                <partial name="_BundleCard" model="bundle" />
            }
        </div>
    </section>
}

@if (Model.AlsoBought.Count > 0)
{
    <section class="content-section">
        <div class="section-heading">
            <h2>Customers also bought</h2>
        </div>
        <div class="album-grid">
            @foreach (var album in Model.AlsoBought)
            {
                <article class="album-card">
                    <a class="album-card-link" href="@Url.Action("Details", "Store", new { id = album.AlbumId })">
                        <img alt="@album.Title" src="@Url.Content(album.GetDisplayThumbnailUrl())" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" />
                        <div class="album-card-body">
                            <h3 class="album-title">@album.Title</h3>
                            <p class="album-price">@album.Artist?.Name</p>
                        </div>
                    </a>
                    <div class="album-card-actions">
                        <a class="btn btn-default btn-block" href="@Url.Action("AddToCart", "ShoppingCart", new { id = album.AlbumId })" aria-label="Add @album.Title to cart">
                            <span class="glyphicon glyphicon-shopping-cart" aria-hidden="true"></span> Add to cart
                        </a>
                    </div>
                </article>
            }
        </div>
    </section>
}

<section class="content-section">
    <div class="section-heading">
        <h2>Related in @Model.Album.Genre!.Name</h2>
    </div>
    @if (Model.RelatedByGenre.Count == 0)
    {
        <p class="section-subtitle">No related albums available yet.</p>
    }
    else
    {
        <div class="album-grid">
        @foreach (var album in Model.RelatedByGenre)
        {
            <article class="album-card">
                <a class="album-card-link" href="@Url.Action("Details", "Store", new { id = album.AlbumId })">
                    <img alt="@album.Title" src="@Url.Content(album.GetDisplayThumbnailUrl())" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" />
                    <div class="album-card-body">
                        <h3 class="album-title">@album.Title</h3>
                        <p class="album-price">@album.Artist?.Name</p>
                    </div>
                </a>
            </article>
        }
        </div>
    }
</section>

<section class="content-section">
    <div class="section-heading">
        <h2>More from @Model.Album.Artist!.Name</h2>
    </div>
    @if (Model.MoreFromArtist.Count == 0)
    {
        <p class="section-subtitle">No additional albums from this artist yet.</p>
    }
    else
    {
        <div class="album-grid">
        @foreach (var album in Model.MoreFromArtist)
        {
            <article class="album-card">
                <a class="album-card-link" href="@Url.Action("Details", "Store", new { id = album.AlbumId })">
                    <img alt="@album.Title" src="@Url.Content(album.GetDisplayThumbnailUrl())" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" />
                    <div class="album-card-body">
                        <h3 class="album-title">@album.Title</h3>
                        <p class="album-price">@album.Genre?.Name</p>
                    </div>
                </a>
            </article>
        }
        </div>
    }
</section>
