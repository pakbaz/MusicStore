@model MvcMusicStore.Models.Genre
@{
    ViewBag.Title = Model.Name + " Albums";
}

<section class="content-section">
    <div class="section-heading">
        <h1>@Model.Name albums</h1>
        <p class="section-subtitle">Browse @Model.Albums!.Count releases in this genre.</p>
    </div>
    <div class="album-grid">
        @foreach (var album in Model.Albums!)
        {
            <article class="album-card">
                <a class="album-card-link" href="@Url.Action("Details", new { id = album.AlbumId })">
                    @if (!string.IsNullOrEmpty(album.AlbumArtUrl))
                    {
                        <img alt="@album.Title" src="@Url.Content(@album.AlbumArtUrl)" />
                    }
                    else
                    {
                        <img alt="@album.Title" src="~/Images/placeholder.png" />
                    }
                    <div class="album-card-body">
                        <h3 class="album-title">@album.Title</h3>
                        <p class="album-price">@album.Price.ToString("C")</p>
                    </div>
                </a>
            </article>
        }
    </div>
</section>