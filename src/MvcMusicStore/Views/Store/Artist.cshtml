@model MvcMusicStore.ViewModels.ArtistDetailsViewModel

@{
    var artist = Model.Artist;
    ViewBag.Title = artist.Name;

    var genres = Model.Albums.Select(a => a.Genre?.Name ?? a.GenreName);
    var canonicalUrl = Url.ArtistUrl(artist.ArtistId, artist.Name, absolute: true);
    var firstAlbum = Model.Albums.FirstOrDefault();
    var imageUrl = firstAlbum != null
        ? Url.AbsoluteAlbumImage(firstAlbum)
        : Url.AbsoluteContent(Seo.DefaultSocialImagePath);

    ViewBag.Seo = new SeoMetadata
    {
        Title = artist.Name,
        Description = Seo.ArtistDescription(artist.Name, Model.Albums.Count, genres),
        CanonicalUrl = canonicalUrl,
        ImageUrl = imageUrl,
        ImageAlt = $"{artist.Name} on {Seo.SiteName}",
        OgType = "profile"
    };

    var albumNodes = Model.Albums.Select(a => (
        Name: a.Title ?? string.Empty,
        Url: Url.AlbumUrl(a.AlbumId, a.Title, absolute: true),
        Image: (string?)Url.AbsoluteAlbumImage(a)));
}

<h2>@Model.Artist.Name</h2>

<section class="discovery-section">
    <h3>Albums by @Model.Artist.Name</h3>
    @if (Model.Albums.Count == 0)
    {
        <p class="text-muted">No albums found for this artist.</p>
    }
    else
    {
        <ul class="list-unstyled row album-grid">
            @foreach (var album in Model.Albums)
            {
                <li class="col-lg-2 col-md-3 col-sm-4 col-xs-6 container">
                    <a href="@Url.AlbumUrl(album.AlbumId, album.Title)">
                        <img alt="@album.Title" src="@Url.Content(album.GetDisplayThumbnailUrl())" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" />
                        <h5>@album.Title</h5>
                    </a>
                    <small class="text-muted">@album.Genre?.Name</small>
                </li>
            }
        </ul>
    }
</section>

<section class="recommendations-section">
    <h3>You may also like</h3>
    @if (Model.RelatedAlbums.Count == 0)
    {
        <p class="text-muted">No related recommendations available yet.</p>
    }
    else
    {
        <ul class="list-unstyled row recommendation-grid">
            @foreach (var album in Model.RelatedAlbums)
            {
                <li class="col-md-3 col-sm-4 col-xs-6 container">
                    <a href="@Url.AlbumUrl(album.AlbumId, album.Title)">
                        <img alt="@album.Title" src="@Url.Content(album.GetDisplayThumbnailUrl())" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" />
                        <h5>@album.Title</h5>
                    </a>
                    <small class="text-muted">@album.Artist?.Name</small>
                </li>
            }
        </ul>
    }
</section>

@Html.Raw(StructuredData.MusicGroup(artist.Name, canonicalUrl, imageUrl, albumNodes))
