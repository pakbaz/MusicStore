@model MvcMusicStore.ViewModels.ShoppingCartViewModel
@{
    ViewBag.Title = "Shopping Cart";
    var hasItems = Model.CartItems != null && Model.CartItems.Count > 0;
}

@section Scripts {
    <script type="text/javascript">
        $(function () {
            var removeUrl = '@Url.Action("RemoveFromCart", "ShoppingCart")';
            var updateUrl = '@Url.Action("UpdateCart", "ShoppingCart")';
            var currencyFormatter = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });

            function formatCurrency(value) {
                return currencyFormatter.format(Number(value) || 0);
            }

            function toggleSummaryVisibility(count) {
                if (count > 0) {
                    $('#cart-summary-item').removeClass('hidden');
                } else {
                    $('#cart-summary-item').addClass('hidden');
                }
            }

            function handleCartUpdate(data) {
                var row = $('#row-' + data.DeleteId);

                if (data.ItemCount === 0) {
                    row.fadeOut('fast', function () {
                        row.remove();
                        if ($('#cart-summary-table tbody tr.cart-row').length === 0) {
                            $('#cart-table-wrapper').addClass('hidden');
                            $('#empty-cart-state').removeClass('hidden');
                        }
                    });
                } else {
                    $('#item-count-' + data.DeleteId).text(data.ItemCount);
                    $('#item-subtotal-' + data.DeleteId).text(formatCurrency(data.ItemSubtotal));
                    $('#quantity-input-' + data.DeleteId).val(data.ItemCount);
                }

                $('#cart-total').text(formatCurrency(data.CartTotal));
                $('#update-message').removeClass('hidden').text(data.Message);
                $('#cart-summary-count').text(data.CartCount);
                $('#cart-summary-link').attr('title', data.CartSummary || 'Your cart is empty');
                toggleSummaryVisibility(data.CartCount);
            }

            function postCartUpdate(recordId, count) {
                $.post(updateUrl, { id: recordId, count: count })
                    .done(handleCartUpdate)
                    .fail(function (xhr) {
                        var errorMessage = xhr.responseText || 'Sorry, we could not update your cart.';
                        $('#update-message').removeClass('hidden').text(errorMessage);
                    });
            }

            $('.js-remove').click(function (event) {
                event.preventDefault();
                var recordId = $(this).data('id');
                $.post(removeUrl, { id: recordId })
                    .done(handleCartUpdate)
                    .fail(function (xhr) {
                        var errorMessage = xhr.responseText || 'Sorry, we could not remove the item.';
                        $('#update-message').removeClass('hidden').text(errorMessage);
                    });
            });

            $('.js-step').click(function () {
                var recordId = $(this).data('id');
                var delta = Number($(this).data('delta'));
                var input = $('#quantity-input-' + recordId);
                var current = Number(input.val());
                var nextCount = Math.max(0, current + delta);
                postCartUpdate(recordId, nextCount);
            });

            $('.js-update').click(function () {
                var recordId = $(this).data('id');
                var input = $('#quantity-input-' + recordId);
                var requestedCount = Math.max(0, Number(input.val()));
                postCartUpdate(recordId, requestedCount);
            });
        });
    </script>
}

<h3><em>Review</em> your cart</h3>

@if (ViewBag.CartMessage != null)
{
    <div class="alert alert-info">@ViewBag.CartMessage</div>
}

<div id="update-message" class="alert alert-info hidden"></div>

<div id="empty-cart-state" class="@(hasItems ? "hidden" : string.Empty)">
    <div class="jumbotron">
        <h2>Your cart is empty</h2>
        <p>Add music you love, then come back to checkout.</p>
        <p>
            <a class="btn btn-primary btn-lg" href="@Url.Action("Index", "Store")">Browse music</a>
        </p>
    </div>
</div>

<div id="cart-table-wrapper" class="@(hasItems ? string.Empty : "hidden")">
    <p>
        <a class="btn btn-primary" href="@Url.Action("AddressAndPayment", "Checkout")">Proceed to checkout</a>
        <a class="btn btn-default" href="@Url.Action("Index", "Store")">Continue shopping</a>
    </p>

    <table id="cart-summary-table" class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Album</th>
                <th class="text-right">Unit price</th>
                <th>Quantity</th>
                <th class="text-right">Subtotal</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.CartItems ?? new List<MvcMusicStore.Models.Cart>())
            {
                var lineSubtotal = (item.Album?.Price ?? decimal.Zero) * item.Count;
                <tr id="row-@item.RecordId" class="cart-row">
                    <td>
                        @Html.ActionLink(item.Album!.Title, "Details", "Store", new { id = item.AlbumId }, null)
                    </td>
                    <td class="text-right">@item.Album!.Price.ToString("C")</td>
                    <td>
                        <div class="input-group cart-quantity-group">
                            <span class="input-group-btn">
                                <button type="button" class="btn btn-default js-step" data-id="@item.RecordId" data-delta="-1">-</button>
                            </span>
                            <input id="quantity-input-@item.RecordId" class="form-control cart-quantity-input" type="number" min="0" value="@item.Count" />
                            <span class="input-group-btn">
                                <button type="button" class="btn btn-default js-step" data-id="@item.RecordId" data-delta="1">+</button>
                            </span>
                        </div>
                    </td>
                    <td id="item-subtotal-@item.RecordId" class="text-right">@lineSubtotal.ToString("C")</td>
                    <td>
                        <button type="button" class="btn btn-default js-update" data-id="@item.RecordId">Update</button>
                        <button type="button" class="btn btn-link js-remove" data-id="@item.RecordId">Remove</button>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="3" class="text-right">Total</th>
                <th id="cart-total" class="text-right">@Model.CartTotal.ToString("C")</th>
                <th></th>
            </tr>
        </tfoot>
    </table>
</div>