@using MvcMusicStore.Services
@model MvcMusicStore.ViewModels.ShoppingCartViewModel
@{
    ViewBag.Title = "Shopping Cart";
    var pricing = Model.Pricing ?? new CartPricing();
    var hasItems = pricing.Lines.Count > 0;
}

@section Scripts {
    <script type="text/javascript">
        $(function () {
            var removeUrl = '@Url.Action("RemoveFromCart", "ShoppingCart")';
            var updateUrl = '@Url.Action("UpdateCart", "ShoppingCart")';
            var currencyFormatter = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });

            function formatCurrency(value) {
                return currencyFormatter.format(Number(value) || 0);
            }

            function toggleSummaryVisibility(count) {
                if (count > 0) {
                    $('#cart-summary-item').removeClass('hidden');
                } else {
                    $('#cart-summary-item').addClass('hidden');
                }
            }

            function updateTotals(data) {
                $('#cart-subtotal').text(formatCurrency(data.Subtotal));
                if (data.DiscountApplied) {
                    $('#cart-discount-row').removeClass('hidden');
                    $('#cart-discount-code').text(data.DiscountCode || '');
                    $('#cart-discount-amount').text('-' + formatCurrency(data.DiscountAmount));
                } else {
                    $('#cart-discount-row').addClass('hidden');
                }
                $('#cart-total').text(formatCurrency(data.CartTotal));
            }

            function handleCartUpdate(data) {
                var row = $('#row-' + data.DeleteId);

                if (data.ItemCount === 0) {
                    row.fadeOut('fast', function () {
                        row.remove();
                        if ($('#cart-summary-table tbody tr.cart-row').length === 0) {
                            $('#cart-table-wrapper').addClass('hidden');
                            $('#empty-cart-state').removeClass('hidden');
                        }
                    });
                } else {
                    $('#item-count-' + data.DeleteId).text(data.ItemCount);
                    $('#item-subtotal-' + data.DeleteId).text(formatCurrency(data.ItemSubtotal));
                    $('#quantity-input-' + data.DeleteId).val(data.ItemCount);
                }

                updateTotals(data);
                $('#update-message').removeClass('hidden').text(data.Message);
                $('#cart-summary-count').text(data.CartCount);
                $('#cart-summary-link').attr('title', data.CartSummary || 'Your cart is empty');
                toggleSummaryVisibility(data.CartCount);
            }

            function postCartUpdate(recordId, count) {
                $.post(updateUrl, { id: recordId, count: count })
                    .done(handleCartUpdate)
                    .fail(function (xhr) {
                        var errorMessage = xhr.responseText || 'Sorry, we could not update your cart.';
                        $('#update-message').removeClass('hidden').text(errorMessage);
                    });
            }

            $('.js-remove').click(function (event) {
                event.preventDefault();
                var recordId = $(this).data('id');
                $.post(removeUrl, { id: recordId })
                    .done(handleCartUpdate)
                    .fail(function (xhr) {
                        var errorMessage = xhr.responseText || 'Sorry, we could not remove the item.';
                        $('#update-message').removeClass('hidden').text(errorMessage);
                    });
            });

            $('.js-step').click(function () {
                var recordId = $(this).data('id');
                var delta = Number($(this).data('delta'));
                var input = $('#quantity-input-' + recordId);
                var current = Number(input.val());
                var nextCount = Math.max(0, current + delta);
                postCartUpdate(recordId, nextCount);
            });

            $('.js-update').click(function () {
                var recordId = $(this).data('id');
                var input = $('#quantity-input-' + recordId);
                var requestedCount = Math.max(0, Number(input.val()));
                postCartUpdate(recordId, requestedCount);
            });
        });
    </script>
}

<h3><em>Review</em> your cart</h3>

@if (ViewBag.CartMessage != null)
{
    <div class="alert alert-info">@ViewBag.CartMessage</div>
}

@if (!string.IsNullOrEmpty(Model.DiscountMessage))
{
    <div class="alert alert-info" role="status">@Model.DiscountMessage</div>
}

<div id="update-message" class="alert alert-info hidden" role="status" aria-live="polite"></div>

<div id="empty-cart-state" class="@(hasItems ? "hidden" : string.Empty)">
    <div class="jumbotron">
        <h2>Your cart is empty</h2>
        <p>Add music you love, then come back to checkout.</p>
        <p>
            <a class="btn btn-primary btn-lg" href="@Url.Action("Index", "Store")">Browse music</a>
        </p>
    </div>
</div>

<div id="cart-table-wrapper" class="@(hasItems ? string.Empty : "hidden")">
    <p>
        <a class="btn btn-primary" href="@Url.Action("AddressAndPayment", "Checkout")" aria-label="Proceed to checkout">Proceed to checkout</a>
        <a class="btn btn-default" href="@Url.Action("Index", "Store")">Continue shopping</a>
    </p>

    <table id="cart-summary-table" class="table table-striped table-bordered">
        <caption class="sr-only">Items in your shopping cart</caption>
        <thead>
            <tr>
                <th scope="col">Album</th>
                <th scope="col" class="text-right">Unit price</th>
                <th scope="col">Quantity</th>
                <th scope="col" class="text-right">Subtotal</th>
                <th scope="col">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var line in pricing.Lines)
            {
                <tr id="row-@line.RecordId" class="cart-row">
                    <td>
                        @Html.ActionLink(line.Title, "Details", "Store", new { id = line.AlbumId }, null)
                        @if (line.IsOnSale)
                        {
                            <span class="sale-badge" title="@line.SaleName">Sale</span>
                        }
                    </td>
                    <td class="text-right">
                        @if (line.IsOnSale)
                        {
                            <span class="price-was">@line.UnitPrice.ToString("C")</span>
                            <span class="price-now">@line.EffectiveUnitPrice.ToString("C")</span>
                        }
                        else
                        {
                            @line.UnitPrice.ToString("C")
                        }
                    </td>
                    <td>
                        <div class="input-group cart-quantity-group">
                            <span class="input-group-btn">
                                <button type="button" class="btn btn-default js-step" data-id="@line.RecordId" data-delta="-1" aria-label="Decrease quantity for @line.Title">-</button>
                            </span>
                            <input id="quantity-input-@line.RecordId" class="form-control cart-quantity-input" type="number" min="0" value="@line.Quantity" aria-label="Quantity for @line.Title" />
                            <span class="input-group-btn">
                                <button type="button" class="btn btn-default js-step" data-id="@line.RecordId" data-delta="1" aria-label="Increase quantity for @line.Title">+</button>
                            </span>
                        </div>
                    </td>
                    <td id="item-subtotal-@line.RecordId" class="text-right">@line.LineSubtotal.ToString("C")</td>
                    <td>
                        <button type="button" class="btn btn-default js-update" data-id="@line.RecordId" aria-label="Update quantity for @line.Title">Update</button>
                        <button type="button" class="btn btn-link js-remove" data-id="@line.RecordId" aria-label="Remove @line.Title from cart">Remove</button>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="3" class="text-right">Subtotal</th>
                <th id="cart-subtotal" class="text-right">@pricing.Subtotal.ToString("C")</th>
                <th></th>
            </tr>
            <tr id="cart-discount-row" class="@(pricing.DiscountApplied ? string.Empty : "hidden")">
                <th colspan="3" class="text-right">
                    Discount (<span id="cart-discount-code">@pricing.AppliedCode</span>)
                </th>
                <th id="cart-discount-amount" class="text-right text-success">-@pricing.DiscountAmount.ToString("C")</th>
                <th></th>
            </tr>
            <tr>
                <th colspan="3" class="text-right">Total</th>
                <th id="cart-total" class="text-right">@pricing.Total.ToString("C")</th>
                <th></th>
            </tr>
        </tfoot>
    </table>

    <div class="discount-panel">
        @if (pricing.DiscountApplied)
        {
            <div class="discount-applied">
                <span class="label label-success">Code @pricing.AppliedCode applied</span>
                <span class="discount-applied-text">You're saving @pricing.DiscountAmount.ToString("C").</span>
                @using (Html.BeginForm("RemoveDiscount", "ShoppingCart", FormMethod.Post, new { @class = "form-inline discount-remove-form" }))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link">Remove</button>
                }
            </div>
        }
        else
        {
            @using (Html.BeginForm("ApplyDiscount", "ShoppingCart", FormMethod.Post, new { @class = "form-inline discount-form", aria_label = "Apply a discount code" }))
            {
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="control-label" for="code">Discount code</label>
                    <input type="text" id="code" name="code" class="form-control" placeholder="e.g. SAVE20" autocomplete="off" />
                </div>
                <button type="submit" class="btn btn-default">Apply code</button>
            }
        }
    </div>
</div>
