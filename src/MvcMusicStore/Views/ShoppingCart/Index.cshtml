@using MvcMusicStore.Services
@model MvcMusicStore.ViewModels.ShoppingCartViewModel
@{
    ViewBag.Title = "Shopping Cart";
}

@section Scripts {
    <script type="text/javascript">
        $(function () {
            var removeUrl = '@Url.Action("RemoveFromCart", "ShoppingCart")';
            var updateUrl = '@Url.Action("UpdateCart", "ShoppingCart")';
            var addItemUrl = '@Url.Action("AddToCartAjax", "ShoppingCart")';
            var addBundleUrl = '@Url.Action("AddBundleToCartAjax", "ShoppingCart")';

            function syncAfterUpdate() {
                var data = $('#cart-data');
                var count = Number(data.attr('data-cart-count')) || 0;
                var summary = data.attr('data-cart-summary') || 'Your cart is empty';
                var message = data.attr('data-cart-message');

                $('#cart-summary-count').text(count);
                $('#cart-summary-link').attr('title', summary);
                if (count > 0) {
                    $('#cart-summary-item').removeClass('hidden');
                } else {
                    $('#cart-summary-item').addClass('hidden');
                }

                if (message) {
                    $('#update-message').removeClass('hidden').text(message);
                }
            }

            function postCart(url, payload) {
                $.post(url, payload)
                    .done(function (html) {
                        $('#cart-contents').html(html);
                        syncAfterUpdate();
                    })
                    .fail(function (xhr) {
                        var errorMessage = xhr.responseText || 'Sorry, we could not update your cart.';
                        $('#update-message').removeClass('hidden').text(errorMessage);
                    });
            }

            $(document).on('click', '.js-remove', function (event) {
                event.preventDefault();
                postCart(removeUrl, { id: $(this).data('id') });
            });

            $(document).on('click', '.js-step', function () {
                var recordId = $(this).data('id');
                var delta = Number($(this).data('delta'));
                var input = $('#quantity-input-' + recordId);
                var nextCount = Math.max(0, Number(input.val()) + delta);
                postCart(updateUrl, { id: recordId, count: nextCount });
            });

            $(document).on('click', '.js-update', function () {
                var recordId = $(this).data('id');
                var requestedCount = Math.max(0, Number($('#quantity-input-' + recordId).val()));
                postCart(updateUrl, { id: recordId, count: requestedCount });
            });

            $(document).on('click', '.js-add-item', function () {
                postCart(addItemUrl, { id: $(this).data('id') });
            });

            $(document).on('click', '.js-add-bundle', function () {
                postCart(addBundleUrl, { id: $(this).data('id') });
            });
        });
    </script>
}

<h3><em>Review</em> your cart</h3>

@if (ViewBag.CartMessage != null)
{
    <div class="alert alert-info">@ViewBag.CartMessage</div>
}

@if (!string.IsNullOrEmpty(Model.DiscountMessage))
{
    <div class="alert alert-info" role="status">@Model.DiscountMessage</div>
}

<div id="update-message" class="alert alert-info hidden" role="status" aria-live="polite"></div>

<div id="cart-contents">
    <partial name="_CartContents" model="Model" />
</div>
