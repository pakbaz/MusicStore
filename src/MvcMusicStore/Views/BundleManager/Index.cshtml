@model IReadOnlyList<MvcMusicStore.Models.Bundle>
@{
    ViewBag.Title = "Manage Bundles";
}

<h2>Manage bundles</h2>

<p>@Html.ActionLink("Create New", "Create", null, new { @class = "btn btn-default" })</p>

@if (Model.Count == 0)
{
    <p>No bundles yet. Create one to start cross-selling.</p>
}
else
{
    <table class="table">
        <tr>
            <th>Title</th>
            <th>Albums</th>
            <th>Regular</th>
            <th>Bundle price</th>
            <th>Savings</th>
            <th>Active</th>
            <th></th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.AlbumCount</td>
                <td>@item.RegularPrice.ToString("C")</td>
                <td>@item.BundlePrice.ToString("C")</td>
                <td>@item.Savings.ToString("C") (@item.SavingsPercent%)</td>
                <td>@(item.IsActive ? "Yes" : "No")</td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = item.BundleId }) |
                    @Html.ActionLink("Details", "Details", new { id = item.BundleId }) |
                    @Html.ActionLink("Delete", "Delete", new { id = item.BundleId })
                </td>
            </tr>
        }
    </table>
}
