@inject Microsoft.AspNetCore.Identity.UserManager<MvcMusicStore.Models.ApplicationUser> UserManager
@if (User.Identity?.IsAuthenticated == true)
{
    <li class="hidden">
        <form asp-controller="Account" asp-action="LogOff" method="post" id="logoutForm">
            @Html.AntiForgeryToken()
        </form>
    </li>
    <li class="nav-greeting">
        @Html.ActionLink("Hi, " + User.Identity.Name, "Manage", "Account", routeValues: null, htmlAttributes: new { title = "Manage" })
    </li>
    <li>
        <a href="#" onclick="document.getElementById('logoutForm').submit(); return false;">Log off</a>
    </li>
}
else
{
    <li>@Html.ActionLink("Register", "Register", "Account", routeValues: null, htmlAttributes: new { id = "registerLink" })</li>
    <li>@Html.ActionLink("Log in", "Login", "Account", routeValues: null, htmlAttributes: new { id = "loginLink" })</li>
}
