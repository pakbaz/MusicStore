@model MvcMusicStore.Models.Order
@using MvcMusicStore.Models

@{
    ViewBag.Title = "Checkout Complete";
    int pointsEarned = (int)(ViewBag.PointsEarned ?? 0);
    int pointsRedeemed = (int)(ViewBag.PointsRedeemed ?? 0);
    int referralBonus = (int)(ViewBag.ReferralBonus ?? 0);
    int newBalance = (int)(ViewBag.NewBalance ?? 0);
    decimal loyaltyDiscount = (decimal)(ViewBag.LoyaltyDiscount ?? 0m);
    decimal orderTotal = (decimal)(ViewBag.OrderTotal ?? Model.Total);
    string tierName = ViewBag.TierName as string ?? "Bronze";
    var downloads = ViewBag.Downloads as List<KeyValuePair<string, string>> ?? new List<KeyValuePair<string, string>>();
    bool isGuest = string.IsNullOrEmpty(Model.Username) && User.Identity?.IsAuthenticated != true;
}

<h2>Checkout Complete</h2>

@switch (Model.PaymentStatus)
{
    case PaymentStatus.Paid:
        <div class="alert alert-success">
            Thanks for your order! Your confirmation number is <strong>@Model.OrderId</strong>.
        </div>
        <p>
            Payment received@(string.IsNullOrEmpty(Model.PaymentProvider) ? "" : $" via {Model.PaymentProvider}").
            Your cart has been cleared and a receipt has been sent to @(string.IsNullOrWhiteSpace(Model.Email) ? "your account email" : Model.Email).
        </p>
        break;
    case PaymentStatus.Pending:
        <div class="alert alert-info">
            Your order <strong>@Model.OrderId</strong> is awaiting payment confirmation.
        </div>
        <p>
            We're still waiting for your payment to be confirmed. This usually only takes a moment — the
            status will update automatically. You can also check
            <a href="@Url.Action("Index", "Order")">your orders</a>.
        </p>
        break;
    case PaymentStatus.Failed:
    case PaymentStatus.Cancelled:
        <div class="alert alert-danger">
            Payment for order <strong>@Model.OrderId</strong> was not completed.
        </div>
        <p>
            No charge was made and your cart still has your items. You can
            <a href="@Url.Action("AddressAndPayment", "Checkout")">try checking out again</a>.
        </p>
        break;
    case PaymentStatus.Refunded:
        <div class="alert alert-warning">
            Order <strong>@Model.OrderId</strong> has been refunded.
        </div>
        break;
}

<h3>Order summary</h3>

<table class="table table-striped table-bordered">
    <caption class="sr-only">Items in your order</caption>
    <thead>
        <tr>
            <th scope="col">Album</th>
            <th scope="col" class="text-right">Unit price</th>
            <th scope="col">Quantity</th>
            <th scope="col" class="text-right">Subtotal</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var detail in Model.OrderDetails ?? new List<MvcMusicStore.Models.OrderDetail>())
        {
            var albumName = string.IsNullOrEmpty(detail.AlbumTitle) ? $"Album #{detail.AlbumId}" : detail.AlbumTitle;
            var lineSubtotal = detail.UnitPrice * detail.Quantity;
            <tr>
                <td>@Html.ActionLink(albumName, "Details", "Store", new { id = detail.AlbumId }, null)</td>
                <td class="text-right">@detail.UnitPrice.ToString("C")</td>
                <td>@detail.Quantity</td>
                <td class="text-right">@lineSubtotal.ToString("C")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="3" class="text-right">Total</th>
            <th class="text-right">@Model.Total.ToString("C")</th>
        </tr>
    </tfoot>
</table>

@if (Model.PaymentStatus == PaymentStatus.Paid && downloads.Count > 0)
{
    <h3>Your downloads</h3>
    <p>Your digital items are ready. These links are also in your confirmation email.</p>
    <ul class="list-unstyled">
        @foreach (var download in downloads)
        {
            <li>
                <span class="glyphicon glyphicon-download-alt" aria-hidden="true"></span>
                <a href="@download.Value" download>@download.Key</a>
            </li>
        }
    </ul>
}

@if (Model.GiftCardAmountApplied > 0)
{
    <div class="panel panel-default">
        <div class="panel-body">
            <dl class="dl-horizontal">
                <dt>Order total</dt>
                <dd>@Model.Total.ToString("C")</dd>
                <dt>Gift card applied</dt>
                <dd>-@Model.GiftCardAmountApplied.ToString("C") (@Model.GiftCardCode)</dd>
                <dt>Amount due</dt>
                <dd>@Model.AmountDue.ToString("C")</dd>
            </dl>
        </div>
    </div>
}

@if (Model.PaymentStatus == PaymentStatus.Paid)
{
    @if (pointsRedeemed > 0)
    {
        <div class="panel panel-default">
            <div class="panel-heading"><strong>Payment summary</strong></div>
            <div class="panel-body">
                <p>Order total: <strong>@orderTotal.ToString("C")</strong></p>
                <p>You redeemed <strong>@pointsRedeemed points</strong> for <strong>@loyaltyDiscount.ToString("C")</strong> off.</p>
            </div>
        </div>
    }

    <div class="panel panel-default">
        <div class="panel-heading"><strong>Rewards earned</strong></div>
        <div class="panel-body">
            <p>
                <span class="glyphicon glyphicon-star" aria-hidden="true"></span>
                You earned <strong>@pointsEarned points</strong> on this order (@tierName tier).
            </p>
            @if (referralBonus > 0)
            {
                <p class="text-success">Plus a <strong>@referralBonus point</strong> referral bonus for your first purchase!</p>
            }
            <p>Your new balance is <strong>@newBalance points</strong>.</p>
            <a href="@Url.Action("Rewards", "Account")">View your rewards &raquo;</a>
        </div>
    </div>
}

@if (isGuest && !string.IsNullOrEmpty(Model.GuestAccessToken) &&
     (Model.PaymentStatus == PaymentStatus.Paid || Model.PaymentStatus == PaymentStatus.Pending))
{
    <div class="panel panel-info">
        <div class="panel-heading"><strong>Create an account</strong></div>
        <div class="panel-body">
            <p>Want your order history and downloads in one place? Create an account and we'll link this order automatically.</p>
            <a class="btn btn-primary" href="@Url.Action("RegisterFromOrder", "Account", new { orderId = Model.OrderId, token = Model.GuestAccessToken, email = Model.Email })">Create account</a>
        </div>
    </div>
}

<p>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a class="btn btn-primary" href="@Url.Action("Details", "Order", new { id = Model.OrderId })">View order details</a>
        <a class="btn btn-default" href="@Url.Action("Index", "Order")">My orders</a>
    }
    <a class="btn btn-default" href="@Url.Action("Index", "Store")">Continue shopping</a>
</p>
