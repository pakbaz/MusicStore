@model MvcMusicStore.Models.Order

@{
    ViewBag.Title = "Checkout Complete";
    int pointsEarned = (int)(ViewBag.PointsEarned ?? 0);
    int pointsRedeemed = (int)(ViewBag.PointsRedeemed ?? 0);
    int referralBonus = (int)(ViewBag.ReferralBonus ?? 0);
    int newBalance = (int)(ViewBag.NewBalance ?? 0);
    decimal loyaltyDiscount = (decimal)(ViewBag.LoyaltyDiscount ?? 0m);
    decimal orderTotal = (decimal)(ViewBag.OrderTotal ?? 0m);
    string tierName = ViewBag.TierName as string ?? "Bronze";
}

<h2>Checkout Complete</h2>

<div class="alert alert-success">
    Thanks for your order! Your confirmation number is <strong>@Model.OrderId</strong>.
</div>

<h3>Order summary</h3>

<table class="table table-striped table-bordered">
    <caption class="sr-only">Items in your order</caption>
    <thead>
        <tr>
            <th scope="col">Album</th>
            <th scope="col" class="text-right">Unit price</th>
            <th scope="col">Quantity</th>
            <th scope="col" class="text-right">Subtotal</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var detail in Model.OrderDetails ?? new List<MvcMusicStore.Models.OrderDetail>())
        {
            var albumName = string.IsNullOrEmpty(detail.AlbumTitle) ? $"Album #{detail.AlbumId}" : detail.AlbumTitle;
            var lineSubtotal = detail.UnitPrice * detail.Quantity;
            <tr>
                <td>@Html.ActionLink(albumName, "Details", "Store", new { id = detail.AlbumId }, null)</td>
                <td class="text-right">@detail.UnitPrice.ToString("C")</td>
                <td>@detail.Quantity</td>
                <td class="text-right">@lineSubtotal.ToString("C")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="3" class="text-right">Total</th>
            <th class="text-right">@Model.Total.ToString("C")</th>
        </tr>
    </tfoot>
</table>

@if (Model.GiftCardAmountApplied > 0)
{
    <div class="panel panel-default">
        <div class="panel-body">
            <dl class="dl-horizontal">
                <dt>Order total</dt>
                <dd>@Model.Total.ToString("C")</dd>
                <dt>Gift card applied</dt>
                <dd>-@Model.GiftCardAmountApplied.ToString("C") (@Model.GiftCardCode)</dd>
                <dt>Amount due</dt>
                <dd>@Model.AmountDue.ToString("C")</dd>
            </dl>
        </div>
    </div>
}

<p>Your order has been placed and your cart has been cleared.</p>

<div class="panel panel-default">
    <div class="panel-heading"><strong>Payment summary</strong></div>
    <div class="panel-body">
        <p>Order total: <strong>@orderTotal.ToString("C")</strong></p>
        @if (pointsRedeemed > 0)
        {
            <p>You redeemed <strong>@pointsRedeemed points</strong> for <strong>@loyaltyDiscount.ToString("C")</strong> off.</p>
        }
    </div>
</div>

<div class="panel panel-default">
    <div class="panel-heading"><strong>Rewards earned</strong></div>
    <div class="panel-body">
        <p>
            <span class="glyphicon glyphicon-star" aria-hidden="true"></span>
            You earned <strong>@pointsEarned points</strong> on this order (@tierName tier).
        </p>
        @if (referralBonus > 0)
        {
            <p class="text-success">Plus a <strong>@referralBonus point</strong> referral bonus for your first purchase!</p>
        }
        <p>Your new balance is <strong>@newBalance points</strong>.</p>
        <a href="@Url.Action("Rewards", "Account")">View your rewards &raquo;</a>
    </div>
</div>

<p>
    <a class="btn btn-primary" href="@Url.Action("Details", "Order", new { id = Model.OrderId })">View order details</a>
    <a class="btn btn-default" href="@Url.Action("Index", "Order")">My orders</a>
    <a class="btn btn-default" href="@Url.Action("Index", "Store")">Continue shopping</a>
</p>