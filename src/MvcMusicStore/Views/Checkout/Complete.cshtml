@model MvcMusicStore.Models.Order
@using MvcMusicStore.Models

@{
    ViewBag.Title = "Checkout Complete";
}

<h2>Checkout Complete</h2>

@switch (Model.PaymentStatus)
{
    case PaymentStatus.Paid:
        <div class="alert alert-success">
            Thanks for your order! Your confirmation number is <strong>@Model.OrderId</strong>.
        </div>
        <p>
            Payment received@(string.IsNullOrEmpty(Model.PaymentProvider) ? "" : $" via {Model.PaymentProvider}").
            Your cart has been cleared and a receipt has been sent to @(string.IsNullOrWhiteSpace(Model.Email) ? "your account email" : Model.Email).
        </p>
        break;
    case PaymentStatus.Pending:
        <div class="alert alert-info">
            Your order <strong>@Model.OrderId</strong> is awaiting payment confirmation.
        </div>
        <p>
            We're still waiting for your payment to be confirmed. This usually only takes a moment — the
            status will update automatically. You can also check
            <a href="@Url.Action("Index", "Order")">your orders</a>.
        </p>
        break;
    case PaymentStatus.Failed:
    case PaymentStatus.Cancelled:
        <div class="alert alert-danger">
            Payment for order <strong>@Model.OrderId</strong> was not completed.
        </div>
        <p>
            No charge was made and your cart still has your items. You can
            <a href="@Url.Action("AddressAndPayment", "Checkout")">try checking out again</a>.
        </p>
        break;
    case PaymentStatus.Refunded:
        <div class="alert alert-warning">
            Order <strong>@Model.OrderId</strong> has been refunded.
        </div>
        break;
}

<h3>Order summary</h3>

<table class="table table-striped table-bordered">
    <caption class="sr-only">Items in your order</caption>
    <thead>
        <tr>
            <th scope="col">Album</th>
            <th scope="col" class="text-right">Unit price</th>
            <th scope="col">Quantity</th>
            <th scope="col" class="text-right">Subtotal</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var detail in Model.OrderDetails ?? new List<MvcMusicStore.Models.OrderDetail>())
        {
            var albumName = string.IsNullOrEmpty(detail.AlbumTitle) ? $"Album #{detail.AlbumId}" : detail.AlbumTitle;
            var lineSubtotal = detail.UnitPrice * detail.Quantity;
            <tr>
                <td>@Html.ActionLink(albumName, "Details", "Store", new { id = detail.AlbumId }, null)</td>
                <td class="text-right">@detail.UnitPrice.ToString("C")</td>
                <td>@detail.Quantity</td>
                <td class="text-right">@lineSubtotal.ToString("C")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="3" class="text-right">Total</th>
            <th class="text-right">@Model.Total.ToString("C")</th>
        </tr>
    </tfoot>
</table>

@if (Model.GiftCardAmountApplied > 0)
{
    <div class="panel panel-default">
        <div class="panel-body">
            <dl class="dl-horizontal">
                <dt>Order total</dt>
                <dd>@Model.Total.ToString("C")</dd>
                <dt>Gift card applied</dt>
                <dd>-@Model.GiftCardAmountApplied.ToString("C") (@Model.GiftCardCode)</dd>
                <dt>Amount due</dt>
                <dd>@Model.AmountDue.ToString("C")</dd>
            </dl>
        </div>
    </div>
}

<p>
    <a class="btn btn-primary" href="@Url.Action("Details", "Order", new { id = Model.OrderId })">View order details</a>
    <a class="btn btn-default" href="@Url.Action("Index", "Order")">My orders</a>
    <a class="btn btn-default" href="@Url.Action("Index", "Store")">Continue shopping</a>
</p>
