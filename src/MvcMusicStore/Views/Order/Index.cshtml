@model IReadOnlyList<MvcMusicStore.Models.Order>
@using MvcMusicStore.Models

@{
    ViewBag.Title = "My Orders";
}

<h2>My Orders</h2>

@if (Model.Count == 0)
{
    <div class="jumbotron">
        <h2>You haven't placed any orders yet</h2>
        <p>When you check out, your orders show up here so you can revisit them anytime.</p>
        <p>
            <a class="btn btn-primary btn-lg" href="@Url.Action("Index", "Store")">Browse music</a>
        </p>
    </div>
}
else
{
    <table class="table table-striped table-bordered">
        <caption class="sr-only">Your past orders</caption>
        <thead>
            <tr>
                <th scope="col">Order #</th>
                <th scope="col">Date</th>
                <th scope="col">Items</th>
                <th scope="col" class="text-right">Total</th>
                <th scope="col">Status</th>
                <th scope="col">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                var itemCount = order.OrderDetails?.Sum(d => d.Quantity) ?? 0;
                <tr>
                    <td>@order.OrderId</td>
                    <td>@order.OrderDate.ToString("g")</td>
                    <td>@itemCount @(itemCount == 1 ? "item" : "items")</td>
                    <td class="text-right">@order.Total.ToString("C")</td>
                    <td>@await Html.PartialAsync("_PaymentStatusBadge", order.PaymentStatus)</td>
                    <td>
                        <a class="btn btn-default btn-sm" href="@Url.Action("Details", "Order", new { id = order.OrderId })" aria-label="View details for order @order.OrderId">View details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
