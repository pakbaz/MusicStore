@model MvcMusicStore.ViewModels.StoreManagerIndexViewModel

@functions {
    string Truncate(string? input, int length)
    {
        if (input == null || input.Length <= length)
            return input ?? string.Empty;
        return input.Substring(0, length) + "...";
    }
}

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
    &nbsp;|&nbsp;
    @Html.ActionLink("Manage Orders", "Orders")
    &nbsp;|&nbsp;
    @Html.ActionLink("Manage bundles", "Index", "BundleManager")
    &nbsp;|&nbsp;
    @Html.ActionLink("Manage reviews", "Reviews")
</p>
<table class="table">
    <tr>
        <th>Genre</th>
        <th>Artist</th>
        <th>Title</th>
        <th>Price</th>
        <th>Release Date</th>
        <th>Available</th>
        <th>Featured Release</th>
        <th>Thumbnail</th>
        <th></th>
    </tr>

    @foreach (var item in Model.Albums)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Genre!.Name)
            </td>
            <td>
                @Truncate(item.Artist!.Name, 25)
            </td>
            <td>
                @Truncate(item.Title, 25)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
            <td>
                @(item.ReleaseDate?.ToString("yyyy-MM-dd") ?? "Unknown")
            </td>
            <td>
                @(item.IsAvailable ? "Yes" : "No")
            </td>
            <td>
                @(item.IsFeatured ? "Yes" : "No")
            </td>
            <td>
                <img alt="@item.Title thumbnail" src="@Url.Content(item.GetDisplayThumbnailUrl())" data-fallback-src="@Url.Content(MvcMusicStore.Models.Album.DefaultPlaceholderThumbnailUrl)" class="admin-thumbnail-list" />
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.AlbumId }) |
                @Html.ActionLink("Details", "Details", new { id = item.AlbumId }) |
                @Html.ActionLink("Delete", "Delete", new { id = item.AlbumId })
            </td>
        </tr>
    }

</table>

@if (Model.TotalPages > 1)
{
    <nav class="store-manager-pagination" aria-label="Catalog pagination">
        @if (Model.HasPreviousPage)
        {
            <a class="btn btn-default" rel="prev" href="@Url.Action("Index", "StoreManager", new { page = Model.Page - 1 })">Previous</a>
        }
        <span class="text-muted">Page @Model.Page of @Model.TotalPages (@Model.TotalResults albums)</span>
        @if (Model.HasNextPage)
        {
            <a class="btn btn-default" rel="next" href="@Url.Action("Index", "StoreManager", new { page = Model.Page + 1 })">Next</a>
        }
    </nav>
}
