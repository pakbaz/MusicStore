@model MvcMusicStore.Models.DiscountCode

@{
    ViewBag.Title = "Edit Discount Code";
}

<h2>Edit discount code</h2>

@using (Html.BeginForm("Edit", "DiscountCodes", new { id = Model.DiscountCodeId }, FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.DiscountCodeId)
    @Html.HiddenFor(m => m.TimesUsed)

    <div class="form-horizontal">
        @Html.ValidationSummary(true)
        @await Html.PartialAsync("_Fields", Model)

        <div class="form-group">
            <div class="col-md-offset-3 col-md-7">
                <input type="submit" value="Save changes" class="btn btn-primary" />
                @Html.ActionLink("Back to list", "Index", null, new { @class = "btn btn-link" })
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="~/Scripts/jquery.validate.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
}
